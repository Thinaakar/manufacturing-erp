
FIREBASE_CREDENTIALS=src/config/ServiceAccountKey.json
# For cloud deploy (Vercel/Railway): paste JSON as one line instead of a file path
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
SESSION_SECRET=change-me-in-production-use-long-random-string
PASSWORD_SALT=forgeos-manufacturing
# Master data: docs seeded per Firestore collection on first run (0 = seed all from DEFAULT_MASTER_DATA)
FIRESTORE_SEED_SAMPLE_LIMIT=2
